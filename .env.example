# Supabase Configuration\nVITE_SUPABASE_URL=https://your-project.supabase.co\nVITE_SUPABASE_ANON_KEY=your_anon_key_here\n\n# Salla Integration\nVITE_SALLA_CLIENT_ID=your_salla_client_id\nVITE_SALLA_CLIENT_SECRET=your_salla_client_secret\nVITE_SALLA_REDIRECT_URI=https://your-domain.com/auth/salla/callback\n\n# Zid Integration\nVITE_ZID_CLIENT_ID=your_zid_client_id\nVITE_ZID_CLIENT_SECRET=your_zid_client_secret\nVITE_ZID_REDIRECT_URI=https://your-domain.com/auth/zid/callback\n\n# Shopify Integration\nVITE_SHOPIFY_CLIENT_ID=your_shopify_client_id\nVITE_SHOPIFY_CLIENT_SECRET=your_shopify_client_secret\nVITE_SHOPIFY_REDIRECT_URI=https://your-domain.com/auth/shopify/callback\n\n# WooCommerce Integration\nVITE_WOOCOMMERCE_STORE_URL=https://your-woocommerce-store.com\nVITE_WOOCOMMERCE_CONSUMER_KEY=your_consumer_key\nVITE_WOOCOMMERCE_CONSUMER_SECRET=your_consumer_secret\n\n# Meta (Facebook) Ads Integration\nVITE_META_APP_ID=your_meta_app_id\nVITE_META_APP_SECRET=your_meta_app_secret\nVITE_META_REDIRECT_URI=https://your-domain.com/auth/meta/callback\n\n# Google Ads Integration\nVITE_GOOGLE_CLIENT_ID=your_google_client_id\nVITE_GOOGLE_CLIENT_SECRET=your_google_client_secret\nVITE_GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback\nVITE_GOOGLE_DEVELOPER_TOKEN=your_google_developer_token\n\n# Application Settings\nVITE_APP_NAME=ProfitPilot\nVITE_APP_URL=https://your-domain.com\nVITE_API_TIMEOUT=30000\nVITE_LOG_LEVEL=info\n\n# Feature Flags\nVITE_ENABLE_SALLA=true\nVITE_ENABLE_ZID=true\nVITE_ENABLE_SHOPIFY=true\nVITE_ENABLE_WOOCOMMERCE=true\nVITE_ENABLE_META_ADS=true\nVITE_ENABLE_GOOGLE_ADS=true\n
